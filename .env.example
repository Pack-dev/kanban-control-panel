# Shared environment for the kanban stack (used by docker-compose).
# Copy to `.env` and fill in real values. `.env` is gitignored.

# REQUIRED.
JWT_SECRET=change-me-to-a-long-random-string

# OPTIONAL: bootstrap admin for an existing user (no-op if email not found).
# Useful on a pre-existing DB volume that pre-dates RBAC.
# PROMOTE_EMAIL=you@example.com

# OPTIONAL: host port nginx publishes (the frontend container listens on :80
# internally; this is the port the browser hits). Default 8080.
# HOST_PORT=8080

# OPTIONAL: only matters if you curl /api from another origin — the browser
# hits the same origin as the SPA when going through nginx, so CORS is mostly
# moot in compose. Default is http://localhost:8080.
# CORS_ORIGIN=http://localhost:8080
