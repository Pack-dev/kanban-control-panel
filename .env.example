# Shared environment for the kanban stack (used by docker-compose AND scripts/dev.sh).
# Copy to `.env` and fill in real values. `.env` is gitignored.

# REQUIRED.
JWT_SECRET=change-me-to-a-long-random-string

# Postgres credentials. The compose `postgres` service creates DB + user on
# first start using these. They're embedded into DATABASE_URL via substitution.
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban
POSTGRES_DB=kanban

# OPTIONAL: bootstrap admin role for an existing user (no-op if email not found).
# Useful on a pre-existing DB volume that pre-dates RBAC.
# PROMOTE_EMAIL=you@example.com

# OPTIONAL: host port nginx publishes (frontend container; the browser hits this).
# HOST_PORT=8080

# OPTIONAL: host port the postgres service publishes (for psql / integration tests
# from the host). Change if 5432 is already taken on your machine.
# POSTGRES_HOST_PORT=5432

# OPTIONAL: only matters if you curl /api from another origin — the browser
# hits the same origin as the SPA when going through nginx, so CORS is mostly
# moot in compose. Default is http://localhost:8080.
# CORS_ORIGIN=http://localhost:8080
