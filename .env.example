# Shared environment for the kanban stack.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- backend ---
JWT_SECRET=change-me-to-a-long-random-string
PORT=8080
DB_PATH=/app/data/app.db
CORS_ORIGIN=http://localhost:5173

# Optional: bootstrap admin role for an existing user (no-op if email not found).
# PROMOTE_EMAIL=you@example.com

# --- frontend ---
# The frontend bundle hard-codes /api as the axios baseURL and relies on Vite's
# dev proxy locally; in docker-compose nginx proxies /api → backend.
VITE_DEV_PORT=5173
